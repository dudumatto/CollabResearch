# Configuração do Playwright E2E
E2E_BASE_URL=http://127.0.0.1:3000

# Credenciais de teste - Aluno
E2E_ALUNO_EMAIL=aluno@teste.com
E2E_ALUNO_PASSWORD=senha123

# Credenciais de teste - Professor
E2E_PROFESSOR_EMAIL=professor@teste.com
E2E_PROFESSOR_PASSWORD=senha123

# Credenciais de teste - Administrador
E2E_ADMIN_EMAIL=admin@teste.com
E2E_ADMIN_PASSWORD=senha123

# Backend API URL
# Em dev: vazio (next.config.mjs rewrites /api/*)
# Em produção: https://tcc-backend-jqod.onrender.com
NEXT_PUBLIC_API_URL=

# Supabase (necessário para upload de documentos)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_SUPABASE_BUCKET=documents
