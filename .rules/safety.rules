prefix_rule(
pattern = ["git", "push"],
decision = "prompt",
justification = "Enviar alteracoes ao repositorio remoto exige confirmacao.",
match = ["git push origin main"],
)

prefix_rule(
pattern = ["git", "reset", "--hard"],
decision = "prompt",
justification = "Este comando pode descartar alteracoes locais.",
match = ["git reset --hard HEAD"],
)

prefix_rule(
pattern = ["git", "clean"],
decision = "prompt",
justification = "Este comando pode apagar arquivos nao rastreados.",
match = ["git clean -fd"],
)

prefix_rule(
pattern = ["git", "branch", "-D"],
decision = "prompt",
justification = "Excluir uma branch exige confirmacao.",
match = ["git branch -D feature/teste"],
)
